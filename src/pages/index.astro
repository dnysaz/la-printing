    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "LA Printing Bali",
        "description": "Percetakan Digital & Offset di Denpasar. Cetak buku, brosur, spanduk, banner, kartu nama, undangan, nota, sticker 24 jam nonstop. Jasa desain grafis undangan, kartu ucapan, spanduk, nota. Kirim file via WhatsApp, antar via Ojol area Denpasar.",
