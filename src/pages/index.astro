import Kontak from '../components/Kontak.astro';
import Footer from '../components/Footer.astro';
import FloatingBar from '../components/FloatingBar.astro';
import MobileMenuScript from '../components/MobileMenuScript.astro';
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://laprintingbali.com" />
    <meta name="description" content="LA Printing Bali - Percetakan Digital & Offset di Denpasar. Cetak buku, brosur, spanduk, banner, kartu nama, undangan, nota, sticker 24 jam. Jasa desain grafis undangan, kartu ucapan, spanduk, nota. Kirim file via WA, antar Ojol Denpasar." />
    <meta name="keywords" content="percetakan Bali, printing Denpasar, cetak buku, cetak brosur, cetak spanduk, cetak banner, cetak kartu nama, cetak undangan, cetak nota, cetak sticker, cetak 24 jam, LA Printing Bali, digital printing Denpasar, offset printing Bali, jasa desain grafis Denpasar, desain undangan, desain kartu ucapan, desain spanduk, desain nota, print nota" />
    <meta name="author" content="LA Printing Bali" />
    <meta name="generator" content="Webkalcer.com" />
    <meta name="theme-color" content="#000000" />
    <meta name="robots" content="index, follow" />
    <meta name="geo.region" content="ID-BA" />
    <meta name="geo.placename" content="Denpasar" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://laprintingbali.com" />
    <meta property="og:title" content="LA Printing Bali - Percetakan Digital & Offset 24 Jam di Denpasar | Harga Bersahabat" />
