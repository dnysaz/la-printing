        "telephone": "+6282144140250",
        "email": "",
        "image": "https://pub-4daa94979ae941b89a5c24997daca63e.r2.dev/la-printing-logo.webp",
        "priceRange": "Rp",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Jl. Gatot Subroto VI No.37, Dangin Puri Kaja",
          "addressLocality": "Denpasar Utara",
          "addressRegion": "Bali",
          "addressCountry": "ID",
          "postalCode": "80233"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -8.633333,
          "longitude": 115.216667
        },
        "openingHours": "Mo-Su 00:00-23:59",
        "areaServed": {
          "@type": "City",
          "name": "Denpasar"
        },
        "sameAs": [
          "https://www.instagram.com/la.printing_bali/"
        ],
        "makesOffer": [
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Cetak Buku"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Cetak Brosur & Flyer"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Cetak Spanduk & Banner"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Cetak Kartu Nama"}},
