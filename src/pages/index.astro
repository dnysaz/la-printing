---
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Hero from '../components/Hero.astro';
import Layanan24Jam from '../components/Layanan24Jam.astro';
import Jasa from '../components/Jasa.astro';
import Produk from '../components/Produk.astro';
import Tentang from '../components/Tentang.astro';
import CaraPesan from '../components/CaraPesan.astro';
