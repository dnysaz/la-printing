    <meta property="og:image" content="https://pub-4daa94979ae941b89a5c24997daca63e.r2.dev/la-printing-logo.webp" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="LA Printing Bali" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="LA Printing Bali - Percetakan Digital & Offset 24 Jam Denpasar" />
    <meta name="twitter:description" content="Cetak buku, brosur, spanduk, banner, kartu nama, undangan, nota, sticker 24 jam. Jasa desain grafis undangan, kartu ucapan, spanduk, nota. Kirim file via WA, antar Ojol Denpasar." />
