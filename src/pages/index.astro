          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Cetak Sticker & Label"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Jasa Desain Grafis"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Desain Undangan"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Desain Kartu Ucapan"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Desain Spanduk & Banner"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Desain Kartu Nama"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Desain Nota"}}
        ]
      }
